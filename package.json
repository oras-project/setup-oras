{
  "name": "setup-oras",
  "version": "0.2.0",
  "description": "Set up your GitHub Actions workflow with a specific version of ORAS",
  "scripts": {
    "build": "esbuild src/setup.ts --bundle --platform=node --format=cjs --target=node24 --legal-comments=external --outfile=dist/index.js && node -e \"const fs=require('fs');const src='dist/index.js.LEGAL.txt';const dst='dist/licenses.txt';if(fs.existsSync(src)){fs.copyFileSync(src,dst);fs.unlinkSync(src);}else{fs.writeFileSync(dst,'');}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oras-project/setup-oras.git"
  },
  "keywords": [],
  "author": "ORAS",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/oras-project/setup-oras/issues"
  },
  "homepage": "https://github.com/oras-project/setup-oras#readme",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/tool-cache": "^4.0.0",
    "@types/node": "^25.5.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "undici": ">=6.24.1"
  }
}
